{
    "name": "ningjing",
    "version": "2.27.4",
    "author": "OPCMate.ai",
    "homepage": "",
    "description": "3D Gaussian Splat Editor",
    "keywords": [
        "playcanvas",
        "ply",
        "gaussian",
        "splat",
        "editor"
    ],
    "license": "MIT",
    "main": "index.js",
    "scripts": {
        "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 rollup -c",
        "build:viewer": "cross-env NODE_OPTIONS=--max-old-space-size=8192 rollup -c rollup.viewer.config.mjs",
        "build:all": "npm run build && npm run build:viewer",
        "build:all:parallel": "concurrently --kill-others -n editor,viewer \"npm run build\" \"npm run build:viewer\"",
        "generate:viewer-video": "node scripts/generate-viewer-brand-video.mjs",
        "watch": "cross-env NODE_OPTIONS=--max-old-space-size=8192 rollup -c -w",
        "watch:viewer": "cross-env NODE_OPTIONS=--max-old-space-size=8192 rollup -c rollup.viewer.config.mjs -w",
        "serve": "serve dist -C -l 1420",
        "serve:viewer": "serve dist-viewer -C -l 1430",
        "develop": "cross-env BUILD_TYPE=debug concurrently --kill-others \"npm run watch\" \"npm run serve\"",
        "develop:viewer": "cross-env BUILD_TYPE=debug concurrently --kill-others \"npm run watch:viewer\" \"npm run serve:viewer\"",
        "develop:auto-launch": "concurrently --kill-others \"xdg-open 'http://localhost:1420/'\" \"npm run watch\" \"npm run serve\"",
        "lint": "eslint src",
        "tauri": "tauri",
        "tauri:editor:dev": "tauri dev",
        "tauri:editor:build": "tauri build",
        "tauri:viewer": "tauri dev --config src-tauri/tauri.viewer.conf.json",
        "tauri:viewer:dev": "tauri dev --config src-tauri/tauri.viewer.conf.json",
        "tauri:viewer:build": "tauri build --config src-tauri/tauri.viewer.conf.json",
        "tauri:build:all": "npm run tauri:editor:build && npm run tauri:viewer:build"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "devDependencies": {
        "@playcanvas/eslint-config": "2.1.0",
        "@playcanvas/pcui": "6.1.4",
        "@playcanvas/splat-transform": "2.5.1",
        "@rollup/plugin-alias": "6.0.0",
        "@rollup/plugin-image": "3.0.3",
        "@rollup/plugin-json": "6.1.0",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@rollup/plugin-strip": "3.0.4",
        "@rollup/plugin-terser": "1.0.0",
        "@rollup/plugin-typescript": "12.3.0",
        "@tauri-apps/cli": "^2.11.2",
        "@types/wicg-file-system-access": "2023.10.7",
        "@typescript-eslint/eslint-plugin": "8.60.1",
        "@typescript-eslint/parser": "8.60.1",
        "autoprefixer": "10.5.0",
        "concurrently": "^9.2.1",
        "cors": "2.8.6",
        "cross-env": "10.1.0",
        "eslint": "10.4.1",
        "eslint-import-resolver-typescript": "4.4.5",
        "globals": "17.6.0",
        "i18next": "26.3.0",
        "i18next-browser-languagedetector": "8.2.1",
        "i18next-http-backend": "3.0.6",
        "mediabunny": "1.46.0",
        "playcanvas": "2.19.2",
        "postcss": "8.5.15",
        "rollup": "4.61.0",
        "rollup-plugin-scss": "4.0.1",
        "sass": "1.100.0",
        "serve": "14.2.6",
        "tslib": "2.8.1",
        "typescript": "6.0.3"
    },
    "overrides": {
        "shell-quote": "1.8.4"
    }
}
